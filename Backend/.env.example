# Server
HOST=0.0.0.0
PORT=8000
RELOAD=true

# PostgreSQL
DATABASE_URL=postgresql://typeahead:typeahead@localhost:5433/typeahead
DB_POOL_MIN=5
DB_POOL_MAX=20

# Redis
REDIS_URL=redis://localhost:6380/0

# Cache
CACHE_NODE_COUNT=3
CACHE_VNODES=150
CACHE_TTL_SECONDS=300

# Batch Writer
BATCH_FLUSH_INTERVAL_SECONDS=5.0
BATCH_MAX_BUFFER_SIZE=100

# Trending
TRENDING_ENABLED=true
TRENDING_WINDOW_MINUTES=60
TRENDING_ALPHA=0.3
TRENDING_BETA=0.7
TRENDING_CLEANUP_INTERVAL_SECONDS=300
